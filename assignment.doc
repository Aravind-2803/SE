<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'><title>Text To Word</title></head><body><p>ASSIGNMENT - I <br>USING IF-ELSE STATEMENT <br>Check whether two numbers are equal <br><br>java <br>import java.util.Scanner; <br>class EqualNumbers { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int a = sc.nextInt(); <br>int b = sc.nextInt(); <br>if (a == b) <br>System.out.println("Numbers are Equal"); <br>else <br>System.out.println("Numbers are Not Equal"); <br>} <br>} <br>Leap year or not <br><br>java <br>import java.util.Scanner; <br>class LeapYear { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int year = sc.nextInt(); <br>if ((year % 4 == 0 &amp;&amp; year % 100 != 0) || year % 400 == 0) <br>System.out.println("Leap Year"); <br>else <br>System.out.println("Not a Leap Year"); <br>} <br>} <br>Odd or Even <br><br>java <br>import java.util.Scanner; <br>class OddEven { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>if (n % 2 == 0) <br>System.out.println("Even"); <br>else <br>System.out.println("Odd"); <br>} <br>} <br>Positive or Negative <br><br>java <br>import java.util.Scanner; <br>class PositiveNegative { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>if (n &gt;= 0) <br>System.out.println("Positive"); <br>else <br>System.out.println("Negative"); <br>} <br>} <br>Biggest among three numbers <br><br>java <br>import java.util.Scanner; <br>class BiggestOfThree { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int a = sc.nextInt(), b = sc.nextInt(), c = sc.nextInt(); <br>if (a &gt; b &amp;&amp; a &gt; c) <br>System.out.println(a + " is largest"); <br>else if (b &gt; c) <br>System.out.println(b + " is largest"); <br>else <br>System.out.println(c + " is largest"); <br>} <br>} <br>Sort three numbers <br><br>java <br>import java.util.Scanner; <br>class SortThree { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int a = sc.nextInt(), b = sc.nextInt(), c = sc.nextInt(); <br>if (a &gt; b) { int t = a; a = b; b = t; } <br>if (a &gt; c) { int t = a; a = c; c = t; } <br>if (b &gt; c) { int t = b; b = c; c = t; } <br>System.out.println(a + " " + b + " " + c); <br>} <br>} <br>Valid Triangle <br><br>java <br>import java.util.Scanner; <br>class TriangleValid { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int a = sc.nextInt(), b = sc.nextInt(), c = sc.nextInt(); <br>if (a + b + c == 180) <br>System.out.println("Valid Triangle"); <br>else <br>System.out.println("Invalid Triangle"); <br>} <br>} <br>Electricity Bill <br><br>java <br>import java.util.Scanner; <br>// Note: The class definition is missing in the snippet. Assuming public static void main... <br>// Scanner sc = new Scanner(System.in); <br>// int units = sc.nextInt(); <br>// double bill; <br>// if (units &lt; 100) bill = units * 2.5; <br>// else if (units &lt;= 250) bill = units * 4.0; <br>// else bill = units * 5.0; <br>// System.out.println("Bill Amount = Rs." + bill); <br>Student Grade <br><br>java <br>import java.util.Scanner; <br>class Grade { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int mark = sc.nextInt(); // Typo in file: sc.nextlnt() <br>if (mark &gt;= 90) System.out.println("Grade S"); <br>else if (mark &gt;= 80) System.out.println("Grade A"); <br>else if (mark &gt;= 70) System.out.println("Grade B"); <br>else if (mark &gt;= 60) System.out.println("Grade C"); <br>else if (mark &gt;= 50) System.out.println("Grade D"); <br>else System.out.println("Grade U"); <br>} <br>} <br>Maximum and Minimum (Only declaration provided, code incomplete) <br><br>Gross Pay &amp; Net Pay <br><br>java <br>import java.util.Scanner; <br>class Salary { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>double basic = sc.nextDouble(); <br>double hra = (basic &gt; 15000) ? basic * 0.10 : basic * 0.05; <br>double dp = basic * 0.10; <br>double da = (basic + dp) * 0.18; <br>double cca = 500, ma = 200; <br>double gpf = (basic + dp) * 0.20; <br>double fbf = (basic + dp) * 0.10; <br>double it = 700; <br>double gross = basic + dp + da + hra + cca + ma; <br>double net = gross - (gpf + fbf + it); <br>System.out.println("Gross Pay = " + gross); <br>System.out.println("Net Pay = " + net); <br>} <br>} <br>Roots of Quadratic Equation <br><br>java <br>import java.util.Scanner; <br>class Quadratic { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>double a = sc.nextDouble(), b = sc.nextDouble(), c = sc.nextDouble(); <br>double d = b*b - 4*a*c; <br>if (d &gt;= 0) { <br>double r1 = (-b + Math.sqrt(d)) / (2*a); <br>double r2 = (-b - Math.sqrt(d)) / (2*a); <br>System.out.println("Roots: " + r1 + ", " + r2); <br>} else { <br>System.out.println("No Real Roots"); <br>} <br>} <br>} <br>USING FOR LOOP <br>Sum of digits (1234 -&gt; 10) <br><br>java <br>import java.util.Scanner; <br>class SumOfDigits { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(), sum = 0; <br>for (; n &gt; 0; n /= 10) sum += n % 10; <br>System.out.println("Sum = " + sum); <br>} <br>} <br>Factorial of a number <br><br>java <br>import java.util.Scanner; <br>class Factorial { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>long fact = 1; <br>for (int i = 1; i &lt;= n; i++) fact *= i; <br>System.out.println("Factorial = " + fact); <br>} <br>} <br>Fibonacci term for a given number <br><br>java <br>import java.util.Scanner; <br>class FibonacciTerm { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>int a = 0, b = 1, c = 0; <br>for (int i = 2; i &lt;= n; i++) { <br>c = a + b; <br>a = b; <br>b = c; <br>} <br>System.out.println("Term = " + b); <br>} <br>} <br>Fibonacci series up to n terms <br><br>java <br>import java.util.Scanner; <br>class FibonacciSeries { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>int a = 0, b = 1; <br>System.out.print(a + " " + b); <br>for (int i = 3; i &lt;= n; i++) { <br>int c = a + b; <br>System.out.print(" " + c); <br>a = b; <br>b = c; <br>} <br>} <br>} <br>Right angle triangle (stars) <br><br>java <br>class StarTriangle { <br>public static void main(String[] args) { <br>for (int i = 1; i &lt;= 3; i++) { <br>for (int j = 1; j &lt;= i; j++) <br>System.out.print("* "); <br>System.out.println(); <br>} <br>} <br>} <br>Number pattern (i) <br><br>java <br>class Pattern1 { <br>public static void main(String[] args) { <br>int n = 3; <br>for (int i = 1; i &lt;= n; i++) { <br>for (int s = n - i; s &gt; 0; s--) System.out.print(" "); <br>for (int j = 1; j &lt;= i; j++) System.out.print(i + " "); <br>System.out.println(); <br>} <br>} <br>} <br>(ii) <br><br>java <br>class Pattern2 { <br>public static void main(String[] args) { <br>for (int i = 1; i &lt;= 3; i++) { <br>for (int j = 1; j &lt;= i; j++) System.out.print(j + " "); <br>System.out.println(); <br>} <br>} <br>} <br>Pattern (stars with spaces) <br><br>java <br>class Pattern7 { <br>public static void main(String[] args) { <br>int n = 3; <br>for (int i = 1; i &lt;= n; i++) { <br>for (int s = n - i; s &gt; 0; s--) System.out.print(" "); <br>for (int j = 1; j &lt;= i; j++) System.out.print(" * "); <br>System.out.println(); <br>} <br>} <br>}JAVA ASSIGNMENT - II <br>1. Position of the biggest number in an array <br>java <br>import java.util.Scanner; <br>class BiggestPosition { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n, max, pos = 0; <br>System.out.print("Enter number of elements: "); <br>n = sc.nextInt(); <br>int a[] = new int[n]; <br>for (int i = 0; i &lt; n; i++) { <br>a[i] = sc.nextInt(); <br>} <br>max = a[0]; <br>for (int i = 1; i &lt; n; i++) { <br>if (a[i] &gt; max) { <br>max = a[i]; <br>pos = i; <br>} <br>} <br>} <br>} <br>2. Reverse a given number using array <br>java <br>import java.util.Scanner; <br>class reverse { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int num, i = 0; <br>System.out.print("Enter number: "); <br>num = sc.nextInt(); <br>int a[] = new int[10]; <br>while (num &gt; 0) { <br>a[i++] = num % 10; <br>num = num / 10; <br>} <br>System.out.print("Reversed number: "); <br>for (int j = 0; j &lt; i; j++) { <br>System.out.print(a[j]); <br>} <br>} <br>} <br>3. Total and average of n numbers <br>Note: The file has a mismatch. The title says "Total and average" but the code calculates "Sum of squares". The correct "totalaverage" class appears on page 4 but is incomplete. <br><br>Sum of squares (provided under #3): <br><br>java <br>import java.util.Scanner; <br>class SumOfSquares { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n, sum = 0; <br>System.out.print("Enter n: "); <br>n = sc.nextInt(); <br>int a[] = new int[n]; <br>for (int i = 0; i &lt; n; i++) { <br>a[i] = sc.nextInt(); <br>sum += a[i] * a[i]; <br>} <br>System.out.println("Sum of squares = " + sum); <br>} <br>} <br>4. Matrix Multiplication <br>java <br>import java.util.Scanner; <br>class matrixmultiplication { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int r1 = sc.nextInt(), c1 = sc.nextInt(); <br>int r2 = sc.nextInt(), c2 = sc.nextInt(); <br>int a[][] = new int[r1][c1]; <br>int b[][] = new int[r2][c2]; <br>int mul[][] = new int[r1][c2]; <br>for (int i = 0; i &lt; r1; i++) <br>for (int j = 0; j &lt; c1; j++) <br>a[i][j] = sc.nextInt(); <br>for (int i = 0; i &lt; r2; i++) <br>for (int j = 0; j &lt; c2; j++) <br>b[i][j] = sc.nextInt(); <br>// Note: Actual multiplication logic is missing in the snippet <br>} <br>} <br>9. Transpose of a matrix <br>java <br>import java.util.Scanner; <br>class TransposeMatrix { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int r = sc.nextInt(); <br>int c = sc.nextInt(); <br>int a[][] = new int[r][c]; <br>for (int i = 0; i &lt; r; i++) <br>for (int j = 0; j &lt; c; j++) <br>a[i][j] = sc.nextInt(); <br>for (int j = 0; j &lt; c; j++) { <br>for (int i = 0; i &lt; r; i++) <br>System.out.print(a[i][j] + " "); <br>System.out.println(); <br>} <br>} <br>} <br>10. Matrix Rotation (90&deg;, 180&deg;, 270&deg;) <br>java <br>import java.util.Scanner; <br>class MatrixRotation { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n; <br>System.out.print("Enter order of square matrix: "); <br>n = sc.nextInt(); <br>int a[][] = new int[n][n]; <br>System.out.println("Enter matrix elements:"); <br>for (int i = 0; i &lt; n; i++) <br>for (int j = 0; j &lt; n; j++) <br>a[i][j] = sc.nextInt(); <br>System.out.println("\nOriginal Matrix:"); <br>printMatrix(a, n); <br>System.out.println("\n90 Degree Rotation:"); <br>rotate90(a, n); <br>System.out.println("\n180 Degree Rotation:"); <br>rotate180(a, n); <br>System.out.println("\n270 Degree Rotation:"); <br>rotate270(a, n); <br>} <br>static void printMatrix(int a[][], int n) { <br>for (int i = 0; i &lt; n; i++) { <br>for (int j = 0; j &lt; n; j++) <br>System.out.print(a[i][j] + " "); <br>System.out.println(); <br>} <br>} <br>static void rotate90(int a[][], int n) { <br>for (int j = 0; j &lt; n; j++) { <br>for (int i = n - 1; i &gt;= 0; i--) <br>System.out.print(a[i][j] + " "); <br>System.out.println(); <br>} <br>} <br>static void rotate180(int a[][], int n) { <br>for (int i = n - 1; i &gt;= 0; i--) { <br>for (int j = n - 1; j &gt;= 0; j--) <br>System.out.print(a[i][j] + " "); <br>System.out.println(); <br>} <br>} <br>static void rotate270(int a[][], int n) { <br>for (int j = n - 1; j &gt;= 0; j--) { <br>for (int i = 0; i &lt; n; i++) <br>System.out.print(a[i][j] + " "); <br>System.out.println(); <br>} <br>} <br>} <br>11. Sort numbers in ascending order (using Arrays.sort) <br>java <br>import java.util.Scanner; <br>import java.util.Arrays; <br>class ascendingsort { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>int a[] = new int[n]; <br>for (int i = 0; i &lt; n; i++) <br>a[i] = sc.nextInt(); <br>Arrays.sort(a); <br>for (int i : a) <br>System.out.print(i + " "); <br>} <br>} <br>12. Bubble sort <br>java <br>import java.util.Scanner; <br>class bubblesort { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>int a[] = new int[n]; <br>for (int i = 0; i &lt; n; i++) <br>a[i] = sc.nextInt(); <br>for (int i = 0; i &lt; n - 1; i++) { <br>for (int j = 0; j &lt; n - i - 1; j++) { <br>if (a[j] &gt; a[j + 1]) { <br>int temp = a[j]; <br>a[j] = a[j + 1]; <br>a[j + 1] = temp; <br>} <br>} <br>} <br>for (int i : a) <br>System.out.print(i + " "); <br>} <br>} <br>JAVA ASSIGNMENT - III <br>1. Convert lowercase to uppercase <br>java <br>import java.util.Scanner; <br>class LowerToUpper { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine(); <br>System.out.println(str.toUpperCase()); <br>} <br>} <br>2. Count number of vowels in a string <br>java <br>import java.util.Scanner; <br>class CountVowels { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine().toLowerCase(); <br>int count = 0; <br>for (char c : str.toCharArray()) { <br>if ("aeiou".indexOf(c) != -1) count++; <br>} <br>System.out.println("Vowels: " + count); <br>} <br>} <br>3. Check palindrome <br>java <br>import java.util.Scanner; <br>class Palindrome { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine(); <br>String rev = new StringBuilder(str).reverse().toString(); <br>if (str.equals(rev)) { <br>System.out.println("Palindrome"); <br>} else { <br>System.out.println("Not Palindrome"); <br>} <br>} <br>} <br>4. Change case of a string (toggle case) <br>java <br>import java.util.Scanner; <br>class ChangeCase { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine(); <br>StringBuilder sb = new StringBuilder(); <br>for (char c : str.toCharArray()) { <br>if (Character.isUpperCase(c)) <br>sb.append(Character.toLowerCase(c)); <br>else <br>sb.append(Character.toUpperCase(c)); <br>} <br>System.out.println(sb); <br>} <br>} <br>5. Count characters, words, and lines <br>java <br>import java.util.Scanner; <br>class CountAll { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine(); <br>int chars = str.length(); <br>int words = str.trim().split("\\s+").length; <br>System.out.println("Characters: " + chars); <br>System.out.println("Words: " + words); <br>System.out.println("Lines: 1"); <br>} <br>} <br>6. Sort strings alphabetically (predefined array) <br>java <br>import java.util.Arrays; <br>class SortStrings { <br>public static void main(String[] args) { <br>String[] arr = {"banana", "apple", "cherry"}; <br>Arrays.sort(arr); <br>for (String s : arr) <br>System.out.println(s); <br>} <br>} <br>7. Sort strings using array (user input) <br>java <br>import java.util.Arrays; <br>import java.util.Scanner; <br>class SortStringArray { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>int n = sc.nextInt(); <br>sc.nextLine(); <br>String[] arr = new String[n]; <br>for (int i = 0; i &lt; n; i++) <br>arr[i] = sc.nextLine(); <br>Arrays.sort(arr); <br>for (String s : arr) <br>System.out.println(s); <br>} <br>} <br>8. Check anagram <br>java <br>import java.util.Arrays; <br>import java.util.Scanner; <br>class Anagram { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String s1 = sc.nextLine(); <br>String s2 = sc.nextLine(); <br>char[] a = s1.toCharArray(); <br>char[] b = s2.toCharArray(); <br>Arrays.sort(a); <br>Arrays.sort(b); <br>System.out.println(Arrays.equals(a, b) ? "Anagram" : "Not Anagram"); <br>} <br>} <br>9. Replace character at specific index <br>java <br>import java.util.Scanner; <br>class ReplaceChar { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine(); <br>int index = sc.nextInt(); <br>char ch = sc.next().charAt(0); <br>String result = str.substring(0, index) + ch + str.substring(index + 1); <br>System.out.println(result); <br>} <br>} <br>10. Remove leading zeros <br>java <br>import java.util.Scanner; <br>class RemoveLeadingZeros { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine(); <br>// Correction: The original had "O+" (letter O) instead of "0+" (zero) <br>System.out.println(str.replaceFirst("^0+(?!$)", "")); <br>} <br>} <br>11. Compare two strings <br>(Code incomplete in file - only class declaration and first string input) <br><br>java <br>import java.util.Scanner; <br>class CompareStrings { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String s1 = sc.nextLine(); <br>String s2 = sc.nextLine(); <br>if (s1.equals(s2)) <br>System.out.println("Equal"); <br>else <br>System.out.println("Not Equal"); <br>} <br>} <br>12. Sum of two large numbers (using BigInteger) <br>java <br>import java.math.BigInteger; <br>import java.util.Scanner; <br>class LargeSum { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>BigInteger a = new BigInteger(sc.nextLine()); <br>BigInteger b = new BigInteger(sc.nextLine()); <br>System.out.println(a.add(b)); <br>} <br>} <br>13. Extract substrings (positions 0,1,2) <br>java <br>import java.util.Scanner; <br>class ExtractSubstring { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String str = sc.nextLine(); <br>System.out.println(str.substring(0)); <br>System.out.println(str.substring(1)); <br>System.out.println(str.substring(2)); <br>} <br>} <br>14. Add binary strings <br>java <br>class AddBinary { <br>public static void main(String[] args) { <br>String a = "1010"; <br>String b = "1101"; <br>int sum = Integer.parseInt(a, 2) + Integer.parseInt(b, 2); <br>System.out.println(Integer.toBinaryString(sum)); <br>} <br>} <br>15. Validate IP address <br>(Code incomplete in file - regex pattern provided) <br><br>java <br>import java.util.Scanner; <br>class ValidateIP { <br>public static void main(String[] args) { <br>Scanner sc = new Scanner(System.in); <br>String ip = sc.nextLine(); <br>String regex = "^(25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\.{3}(25[0-5]|2[0-4]\\d|[01]?\\d\\d?)$"; <br>System.out.println(ip.matches(regex) ? "Valid IP" : "Invalid IP"); <br>} <br>} <br>16. Print all permutations of a string <br>java <br>class Permutations { <br>static void permute(String str, String ans) { <br>if (str.length() == 0) { <br>System.out.println(ans); <br>return; <br>} <br>for (int i = 0; i &lt; str.length(); i++) { <br>permute(str.substring(0, i) + str.substring(i + 1), ans + str.charAt(i)); <br>} <br>} <br>public static void main(String[] args) { <br>String str = "abc"; <br>permute(str, ""); <br>} <br>} <br>17. Generate strong password <br>java <br>import java.util.Random; <br>class StrongPassword { <br>public static void main(String[] args) { <br>String upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"; <br>String lower = "abcdefghijklmnopqrstuvwxyz"; <br>String numbers = "0123456789"; <br>String symbols = "!@#$%^&amp;*"; <br>String all = upper + lower + numbers + symbols; <br>Random r = new Random(); <br>StringBuilder password = new StringBuilder(); <br>for (int i = 0; i &lt; 12; i++) { <br>password.append(all.charAt(r.nextInt(all.length()))); <br>} <br>System.out.println("Strong Password: " + password); <br>} <br>} <br>JAVA ASSIGNMENT - IV <br>1. Abstract Class: Animal <br>java <br>abstract class Animal { <br>abstract void sound(); <br>} <br><br>class Lion extends Animal { <br>public void sound() { <br>System.out.println("Lion roars"); <br>} <br>} <br><br>class Tiger extends Animal { <br>public void sound() { <br>System.out.println("Tiger growls"); <br>} <br>} <br><br>public class MainAnimal { <br>public static void main(String[] args) { <br>Animal a1 = new Lion(); <br>Animal a2 = new Tiger(); <br>a1.sound(); <br>a2.sound(); <br>} <br>} <br>2. Abstract Class: Shape (Area &amp; Perimeter) <br>java <br>abstract class Shape { <br>abstract double calculateArea(); <br>abstract double calculatePerimeter(); <br>} <br><br>class Circle extends Shape { <br>double r = 5; <br>double calculateArea() { <br>return Math.PI * r * r; <br>} <br>double calculatePerimeter() { <br>return 2 * Math.PI * r; <br>} <br>} <br><br>class Triangle extends Shape { <br>double a = 3, b = 4, c = 5; <br>double calculateArea() { <br>return 0.5 * a * b; <br>} <br>double calculatePerimeter() { <br>return a + b + c; <br>} <br>} <br><br>public class MainShape { <br>public static void main(String[] args) { <br>Shape s1 = new Circle(); <br>Shape s2 = new Triangle(); <br>System.out.println("Circle Area: " + s1.calculateArea()); <br>System.out.println("Triangle Perimeter: " + s2.calculatePerimeter()); <br>} <br>} <br>3. Abstract Class: BankAccount <br>java <br>abstract class BankAccount { <br>double balance = 1000; <br>abstract void deposit(double amount); <br>abstract void withdraw(double amount); <br>} <br><br>class SavingsAccount extends BankAccount { <br>void deposit(double amount) { <br>balance += amount; <br>System.out.println("Savings Balance: " + balance); <br>} <br>void withdraw(double amount) { <br>balance -= amount; <br>System.out.println("Savings Balance: " + balance); <br>} <br>} <br><br>class CurrentAccount extends BankAccount { <br>void deposit(double amount) { <br>balance += amount; <br>System.out.println("Current Balance: " + balance); <br>} <br>void withdraw(double amount) { <br>balance -= amount; <br>System.out.println("Current Balance: " + balance); <br>} <br>} <br><br>public class MainBank { <br>public static void main(String[] args) { <br>BankAccount acc = new SavingsAccount(); <br>acc.deposit(500); <br>acc.withdraw(200); <br>} <br>} <br>4. Abstract Class: Employee <br>java <br>abstract class Employee { <br>abstract double calculateSalary(); <br>abstract void displayInfo(); <br>} <br><br>class Manager extends Employee { <br>double salary = 50000; <br>double calculateSalary() { <br>return salary; <br>} <br>void displayInfo() { <br>System.out.println("Manager Salary: " + salary); <br>} <br>} <br><br>class Programmer extends Employee { <br>double salary = 40000; <br>double calculateSalary() { <br>return salary; <br>} <br>void displayInfo() { <br>System.out.println("Programmer Salary: " + salary); <br>} <br>} <br><br>public class MainEmployee { <br>public static void main(String[] args) { <br>Employee e1 = new Manager(); <br>Employee e2 = new Programmer(); <br>e1.displayInfo(); <br>e2.displayInfo(); <br>} <br>} <br>5. Abstract Class: Shape3D (Sphere &amp; Cube) <br>java <br>abstract class Shape3D { <br>abstract double calculateVolume(); <br>abstract double calculateSurfaceArea(); <br>} <br><br>class Sphere extends Shape3D { <br>double r = 3; <br>double calculateVolume() { <br>return (4.0 / 3) * Math.PI * r * r * r; <br>} <br>double calculateSurfaceArea() { <br>return 4 * Math.PI * r * r; <br>} <br>} <br><br>class Cube extends Shape3D { <br>double side = 4; <br>double calculateVolume() { <br>return side * side * side; <br>} <br>double calculateSurfaceArea() { <br>return 6 * side * side; <br>} <br>} <br><br>public class Main3D { <br>public static void main(String[] args) { <br>Shape3D s = new Sphere(); <br>System.out.println("Sphere Volume: " + s.calculateVolume()); <br>} <br>} <br>6. Abstract Class: Shape2D (Draw &amp; Resize) <br>java <br>abstract class Shape2D { <br>abstract void draw(); <br>abstract void resize(); <br>} <br><br>class Rectangle extends Shape2D { <br>void draw() { <br>System.out.println("Drawing Rectangle"); <br>} <br>void resize() { <br>System.out.println("Resizing Rectangle"); <br>} <br>} <br><br>class Circle2D extends Shape2D { <br>void draw() { <br>System.out.println("Drawing Circle"); <br>} <br>void resize() { <br>System.out.println("Resizing Circle"); <br>} <br>} <br><br>public class Main2D { <br>public static void main(String[] args) { <br>Shape2D s = new Rectangle(); <br>s.draw(); <br>s.resize(); <br>} <br>} <br>7. Abstract Class: GeometricShape (Triangle &amp; Square) <br>java <br>abstract class GeometricShape { <br>abstract double area(); <br>abstract double perimeter(); <br>} <br><br>class Triangle2 extends GeometricShape { <br>double a = 3, b = 4, c = 5; <br>double area() { <br>return 0.5 * a * b; <br>} <br>double perimeter() { <br>return a + b + c; <br>} <br>} <br><br>class Square extends GeometricShape { <br>double side = 4; <br>double area() { <br>return side * side; <br>} <br>double perimeter() { <br>return 4 * side; <br>} <br>} <br><br>public class MainGeo { <br>public static void main(String[] args) { <br>GeometricShape g = new Square(); <br>System.out.println("Square Area: " + g.area()); <br>System.out.println("Square Perimeter: " + g.perimeter()); <br>} <br>} <br>Program 1: Current Date/Time, Hour, Minute, Week of Year <br>java <br>package Mypackage; <br><br>import java.time.LocalDateTime; <br>import java.time.format.DateTimeFormatter; <br>import java.time.temporal.WeekFields; <br>import java.util.Locale; <br><br>public class date1 { <br>public static void main(String[] args) { <br>LocalDateTime now = LocalDateTime.now(); <br>System.out.println("Current Date/Time: " + now); <br>System.out.println("Hour: " + now.getHour() + " Minute: " + now.getMinute()); <br>int weekOfYear = now.get(WeekFields.of(Locale.getDefault()).weekOfYear()); <br>System.out.println("Week of Year: " + weekOfYear); <br>} <br>} <br>Program 2: AM/PM, 24-Hour Format, Seconds Only <br>java <br>package Mypackage; <br><br>import java.time.LocalTime; <br>import java.time.format.DateTimeFormatter; <br><br>public class date2 { <br>public static void main(String[] args) { <br>LocalTime time = LocalTime.now(); <br>System.out.println("AM/PM: " + time.format(DateTimeFormatter.ofPattern("hh:mm a"))); <br>String input = "02:30 PM"; <br>LocalTime parsed = LocalTime.parse(input, DateTimeFormatter.ofPattern("hh:mm a")); <br>System.out.println("24-Hour Format: " + parsed.format(DateTimeFormatter.ofPattern("HH:mm"))); <br>System.out.println("Seconds only: " + time.format(DateTimeFormatter.ofPattern("ss"))); <br>} <br>} <br>Program 3: Month Names and All Days of Week <br>java <br>package Mypackage; <br><br>import java.time.LocalDateTime; <br>import java.time.format.DateTimeFormatter; <br>import java.time.DayOfWeek; <br>import java.util.Locale; <br><br>public class date3 { <br>public static void main(String[] args) { <br>LocalDateTime now = LocalDateTime.now(); <br>System.out.println("Month (MMM): " + now.format(DateTimeFormatter.ofPattern("MMM"))); <br>System.out.println("Month (MMMM): " + now.format(DateTimeFormatter.ofPattern("MMMM"))); <br>for (DayOfWeek day : DayOfWeek.values()) { <br>System.out.print(day.getDisplayName(java.time.format.TextStyle.FULL, Locale.getDefault()) + " "); <br>} <br>} <br>} <br>Program 4: French Format and Tokyo Time <br>java <br>package Mypackage; <br><br>import java.time.ZonedDateTime; <br>import java.time.ZoneId; <br>import java.time.format.DateTimeFormatter; <br>import java.util.Locale; <br><br>public class date4 { <br>public static void main(String[] args) { <br>ZonedDateTime now = ZonedDateTime.now(); <br>DateTimeFormatter frenchFormatter = DateTimeFormatter.ofPattern("EEEE dd MMMM yyyy HH:mm", Locale.FRANCE); <br>System.out.println("French Format: " + now.format(frenchFormatter)); <br>ZonedDateTime tokyoTime = ZonedDateTime.now(ZoneId.of("Asia/Tokyo")); <br>System.out.println("Tokyo Time: " + tokyoTime.format(DateTimeFormatter.ofPattern("HH:mm"))); <br>} <br>} <br>Program 5: Future Date and Rolled Hour <br>java <br>package Mypackage; <br><br>import java.time.LocalDateTime; <br><br>public class date5 { <br>public static void main(String[] args) { <br>LocalDateTime now = LocalDateTime.now(); <br>LocalDateTime future = now.plusHours(2).plusDays(10); <br>System.out.println("Future Date: " + future); <br>int rolledHour = (now.getHour() + 5) % 24; <br>System.out.println("Rolled Hour (current + 5): " + rolledHour); <br>} <br>} <br>Program 6: Multiple Date Formats <br>java <br>package Mypackage; <br><br>import java.time.LocalDateTime; <br>import java.time.format.DateTimeFormatter; <br><br>public class date6 { <br>public static void main(String[] args) { <br>LocalDateTime now = LocalDateTime.now(); <br>String[] formats = {"dd/MM/yyyy", "yyyy-MM-dd", "E, MMM dd yyyy", "MMMM dd"}; <br>for (String f : formats) { <br>System.out.println(f + " -&gt; " + now.format(DateTimeFormatter.ofPattern(f))); <br>} <br>} <br>} <br>Program 7: Current Seconds <br>java <br>package Mypackage; <br><br>import java.time.LocalTime; <br>import java.time.format.DateTimeFormatter; <br><br>public class date7 { <br>public static void main(String[] args) { <br>LocalTime time = LocalTime.now(); <br>DateTimeFormatter dtf = DateTimeFormatter.ofPattern("ss"); <br>System.out.println("Current Seconds: " + time.format(dtf)); <br>} <br>} <br>Program 8: Current Month (Abbreviated) <br>java <br>package Mypackage; <br><br>import java.time.LocalDate; <br>import java.time.format.DateTimeFormatter; <br><br>public class date8 { <br>public static void main(String[] args) { <br>LocalDate date = LocalDate.now(); <br>System.out.println("Month: " + date.format(DateTimeFormatter.ofPattern("MMM"))); <br>} <br>} <br>Program 9: All Days of the Week (Full Names) <br>java <br>package Mypackage; <br><br>import java.time.DayOfWeek; <br>import java.time.format.TextStyle; <br>import java.util.Locale; <br><br>public class date9 { <br>public static void main(String[] args) { <br>System.out.println("Days of the week:"); <br>for (DayOfWeek day : DayOfWeek.values()) { <br>System.out.println(day.getDisplayName(TextStyle.FULL, Locale.ENGLISH)); <br>} <br>} <br>} <br>Program 10: Add Days, Hours, Minutes to Current DateTime <br>java <br>package Mypackage; <br><br>import java.time.LocalDateTime; <br><br>public class date10 { <br>public static void main(String[] args) { <br>LocalDateTime now = LocalDateTime.now(); <br>LocalDateTime modified = now.plusDays(5).plusHours(2).plusMinutes(30); <br>System.out.println("Original: " + now); <br>System.out.println("Modified: " + modified); <br>} <br>} <br>Program 11: US vs UK Date Formats <br>java <br>package Mypackage; <br><br>import java.time.ZonedDateTime; <br>import java.time.format.DateTimeFormatter; <br>import java.util.Locale; <br><br>public class date11 { <br>public static void main(String[] args) { <br>ZonedDateTime now = ZonedDateTime.now(); <br>System.out.println("US: " + now.format(DateTimeFormatter.ofPattern("MM/dd/yyyy", Locale.US))); <br>System.out.println("UK: " + now.format(DateTimeFormatter.ofPattern("dd/MM/yyyy", Locale.UK))); <br>} <br>} <br>Program 12: German and French Month/Day Formats <br>java <br>package Mypackage; <br><br>import java.time.LocalDateTime; <br>import java.time.format.DateTimeFormatter; <br>import java.util.Locale; <br><br>public class date12 { <br>public static void main(String[] args) { <br>LocalDateTime now = LocalDateTime.now(); <br>System.out.println("German: " + now.format(DateTimeFormatter.ofPattern("EEEE, MMMM", Locale.GERMANY))); <br>System.out.println("French: " + now.format(DateTimeFormatter.ofPattern("EEEE, MMMM", Locale.FRANCE))); <br>} <br>} <br>Program 13: Rolled Hour (Current Hour + 5) <br>java <br>package Mypackage; <br><br>import java.time.LocalDateTime; <br><br>public class date13 { <br>public static void main(String[] args) { <br>LocalDateTime now = LocalDateTime.now(); <br>int rolledHour = (now.getHour() + 5) % 24; <br>System.out.println("Current Hour: " + now.getHour()); <br>System.out.println("Rolled Hour (+5): " + rolledHour); <br>} <br>} <br>Program 14: Current Week of the Year <br>java <br>package Mypackage; <br><br>import java.time.LocalDate; <br>import java.time.temporal.WeekFields; <br>import java.util.Locale; <br><br>public class date14 { <br>public static void main(String[] args) { <br>LocalDate today = LocalDate.now(); <br>int week = today.get(WeekFields.of(Locale.getDefault()).weekOfYear()); <br>System.out.println("Current Week of the Year: " + week); <br>} <br>} <br>Program 15: Multiple Date Formats (Date only) <br>java <br>package Mypackage; <br><br>import java.time.LocalDate; <br>import java.time.format.DateTimeFormatter; <br><br>public class date15 { <br>public static void main(String[] args) { <br>LocalDate date = LocalDate.now(); <br>String[] formats = {"dd-MM-yyyy", "yyyy/MM/dd", "E, MMM dd 'yy"}; <br>for (String pattern : formats) { <br>System.out.println(pattern + " -&gt; " + date.format(DateTimeFormatter.ofPattern(pattern))); <br>} <br>} <br>} <br>AVA ASSIGNMENT - COLLECTIONS <br>1. Sort an ArrayList of Strings alphabetically <br>java <br>import java.util.*; <br><br>class q1 { <br>public static void main(String[] args) { <br>ArrayList&lt;String&gt; neww = new ArrayList&lt;&gt;(); <br>neww.add("Ankush"); <br>neww.add("Madhan"); <br>neww.add("Gokul"); <br>Collections.sort(neww); <br>System.out.println("Sorted Array: " + neww); <br>} <br>} <br>2. Find the maximum element from an ArrayList of Integers <br>java <br>import java.util.*; <br><br>class q2 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(1, 2, 45, 6453, 17, -34)); <br>System.out.println("Max element in the array is: " + Collections.max(neww)); <br>} <br>} <br>3. Remove all duplicate elements from an ArrayList <br>java <br>import java.util.*; <br><br>class q3 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(1, 2, 1, 23, 2, 2, 4, 1, 3)); <br>Set&lt;Integer&gt; set = new HashSet&lt;&gt;(neww); <br>System.out.println("List after removing duplicates: " + set); <br>} <br>} <br>4. Create an ArrayList and perform add, remove, and iterate operations <br>java <br>import java.util.*; <br><br>class q4 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(); <br>neww.add(97); <br>neww.add(23); <br>neww.add(27); <br>neww.add(90); <br>neww.remove(Integer.valueOf(23)); <br>for (Integer i : neww) { <br>System.out.println(i); <br>} <br>} <br>} <br>5. Find the intersection of two ArrayLists <br>java <br>import java.util.*; <br><br>class q5 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(10, 20, 30, 40, 50)); <br>ArrayList&lt;Integer&gt; old = new ArrayList&lt;&gt;(Arrays.asList(30, 40, 60, 70)); <br>neww.retainAll(old); <br>System.out.println("Intersection: " + neww); <br>} <br>} <br>6. Shuffle the elements of an ArrayList <br>java <br>import java.util.*; <br><br>class q6 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(10, 20, 30, 40, 50)); <br>System.out.println("Before shuffle: " + neww); <br>Collections.shuffle(neww); <br>System.out.println("After shuffle: " + neww); <br>} <br>} <br>7. Find the second-largest element in an ArrayList of Integers <br>java <br>import java.util.*; <br><br>class q7 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(10, 20, 30, 40, 50)); <br>neww.remove(Collections.max(neww)); <br>System.out.println("Second largest element in the array is: " + Collections.max(neww)); <br>} <br>} <br>8. Find the frequency of each element in an ArrayList <br>java <br>import java.util.*; <br><br>class q8 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(10, 20, 30, 40, 50, 10, 20, 90, 50)); <br>HashMap&lt;Integer, Integer&gt; dict = new HashMap&lt;&gt;(); <br>for (Integer i : neww) { <br>dict.put(i, dict.getOrDefault(i, 0) + 1); <br>} <br>System.out.println("Element frequencies:"); <br>for (Map.Entry&lt;Integer, Integer&gt; entry : dict.entrySet()) { <br>System.out.println(entry.getKey() + " -&gt; " + entry.getValue()); <br>} <br>} <br>} <br>9. Find the kth smallest element in an ArrayList <br>java <br>import java.util.*; <br><br>class q9 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(345, 56, 2, 33, 56, -1, 2, 3, 550, -223)); <br>Scanner in = new Scanner(System.in); <br>System.out.print("Enter k: "); <br>int k = in.nextInt(); <br>int minn = 0; <br>for (int i = 0; i &lt; k; i++) { <br>minn = Collections.min(neww); <br>neww.remove(Integer.valueOf(minn)); <br>} <br>System.out.println("The " + k + "th smallest number is: " + minn); <br>in.close(); <br>} <br>} <br>10. Merge two ArrayLists into a single ArrayList <br>java <br>import java.util.*; <br><br>class q10 { <br>public static void main(String[] args) { <br>ArrayList&lt;Integer&gt; neww = new ArrayList&lt;&gt;(Arrays.asList(10, 20, 30)); <br>ArrayList&lt;Integer&gt; old = new ArrayList&lt;&gt;(Arrays.asList(40, 50, 60)); <br>System.out.println("List1: " + neww); <br>System.out.println("List2: " + old); <br>neww.addAll(old); <br>System.out.println("Merged list: " + neww); <br>} <br>} <br>11. Create a LinkedList and perform add, remove, and iterate operations <br>java <br>import java.util.*; <br><br>class q11 { <br>public static void main(String[] args) { <br>LinkedList&lt;Integer&gt; neww = new LinkedList&lt;&gt;(); <br>neww.addFirst(10); <br>neww.addFirst(20); <br>neww.addFirst(30); <br>neww.addFirst(40); <br>neww.addFirst(45); <br>neww.addFirst(60); <br>System.out.println("Original list:"); <br>for (Integer i : neww) { <br>System.out.println(i); <br>} <br>neww.remove(Integer.valueOf(20)); <br>neww.remove(Integer.valueOf(30)); <br>neww.remove(Integer.valueOf(45)); <br>neww.remove(Integer.valueOf(60)); <br>System.out.println("After removing: " + neww); <br>} <br>} <br>12. Implement a Queue using the LinkedList class <br>java <br>import java.util.*; <br><br>class q12 { <br>public static void enqueue(LinkedList&lt;Integer&gt; listt, int num) { <br>listt.add(num); <br>} <br><br>public static int dequeue(LinkedList&lt;Integer&gt; listt) { <br>if (listt.isEmpty()) { <br>System.out.println("Queue is empty!"); <br>return -1; <br>} <br>return listt.remove(); <br>} <br><br>public static int peekfront(LinkedList&lt;Integer&gt; listt) { <br>if (listt.isEmpty()) { <br>System.out.println("Queue is empty!"); <br>return -1; <br>} <br>return listt.peek(); <br>} <br><br>public static void traverse(LinkedList&lt;Integer&gt; listt) { <br>for (Integer i : listt) <br>System.out.println(i); <br>} <br><br>public static void main(String[] args) { <br>LinkedList&lt;Integer&gt; queue = new LinkedList&lt;&gt;(); <br><br>enqueue(queue, 27); <br>enqueue(queue, 37); <br>enqueue(queue, 56); <br>enqueue(queue, 256); <br>enqueue(queue, 7859); <br>enqueue(queue, 0); <br>enqueue(queue, 1); <br><br>System.out.println("Queue elements:"); <br>traverse(queue); <br><br>System.out.println("Dequeued element: " + dequeue(queue)); <br>System.out.println("Dequeued element: " + dequeue(queue)); <br>System.out.println("Dequeued element: " + dequeue(queue)); <br>System.out.println("Dequeued element: " + dequeue(queue)); <br>System.out.println("\nFront element is: " + peekfront(queue)); <br>} <br>} <br>13. Implement a Stack using the LinkedList class <br>java <br>import java.util.*; <br><br>class q13 { <br>public static void push(LinkedList&lt;Integer&gt; stack, int num) { <br>stack.addLast(num); <br>} <br><br>public static int pop(LinkedList&lt;Integer&gt; stack) { <br>if (stack.isEmpty()) { <br>System.out.println("Stack is empty!"); <br>return -1; <br>} <br>return stack.removeLast(); <br>} <br><br>public static int peek(LinkedList&lt;Integer&gt; stack) { <br>if (stack.isEmpty()) { <br>System.out.println("Stack is empty!"); <br>return -1; <br>} <br>return stack.getLast(); <br>} <br><br>public static void traverse(LinkedList&lt;Integer&gt; stack) { <br>System.out.println("Stack elements (bottom -&gt; top):"); <br>for (Integer i : stack) { <br>System.out.println(i); <br>} <br>} <br><br>public static void main(String[] args) { <br>LinkedList&lt;Integer&gt; stack = new LinkedList&lt;&gt;(); <br><br>push(stack, 10); <br>push(stack, 20); <br>push(stack, 30); <br>push(stack, 40); <br><br>traverse(stack); <br>System.out.println("\nTop element is: " + peek(stack)); <br>System.out.println("Popped element: " + pop(stack)); <br>System.out.println("Popped element: " + pop(stack)); <br><br>System.out.println(); <br>traverse(stack); <br>System.out.println("\nTop element is: " + peek(stack)); <br>} <br>} <br>14. Check if two LinkedLists are equal <br>java <br>import java.util.*; <br><br>class q14 { <br>public static void main(String[] args) { <br>LinkedList&lt;Integer&gt; neww = new LinkedList&lt;&gt;(Arrays.asList(1, 2, 3, 4, 5, 6, 7, 8)); <br>LinkedList&lt;Integer&gt; old = new LinkedList&lt;&gt;(Arrays.asList(1, 2, 3, 4, 5, 6, 9, 8)); <br><br>if (neww.equals(old)) { <br>System.out.println("List1 and List2 are equal"); <br>} else { <br>System.out.println("List1 and List2 are NOT equal"); <br>} <br>} <br>} <br>1. Write a program to iterate HashMap <br>java <br>import java.util.HashMap; <br><br>public class IterateHashMap { <br>public static void main(String[] args) { <br>HashMap&lt;Integer, String&gt; fruits = new HashMap&lt;&gt;(); <br>fruits.put(1, "Apple"); <br>fruits.put(2, "Banana"); <br>fruits.put(3, "Mango"); <br>fruits.put(4, "Orange"); <br><br>System.out.println("Fruits List: " + fruits); <br>System.out.println("Fruit with key 2: " + fruits.get(2)); <br><br>System.out.println("Iterating HashMap:"); <br>for (Integer key : fruits.keySet()) { <br>System.out.println("Key: " + key + " Value: " + fruits.get(key)); <br>} <br>} <br>} <br>2. Write a program to check if a key exists in a HashMap <br>java <br>import java.util.HashMap; <br><br>public class CheckKeyExample { <br>public static void main(String[] args) { <br>HashMap&lt;Integer, String&gt; fruits = new HashMap&lt;&gt;(); <br>fruits.put(1, "Apple"); <br>fruits.put(2, "Banana"); <br>fruits.put(3, "Mango"); <br><br>int keyToCheck = 2; <br>if (fruits.containsKey(keyToCheck)) { <br>System.out.println("Key " + keyToCheck + " exists."); <br>System.out.println("Value: " + fruits.get(keyToCheck)); <br>} else { <br>System.out.println("Key " + keyToCheck + " does not exist."); <br>} <br>} <br>} <br>3. Java Program to find the occurrence of words in a String using HashMap <br>java <br>import java.util.HashMap; <br><br>public class WordOccurrence { <br>public static void main(String[] args) { <br>String sentence = "apple banana apple mango banana apple"; <br>HashMap&lt;String, Integer&gt; wordCount = new HashMap&lt;&gt;(); <br>String[] words = sentence.split(" "); <br><br>for (String word : words) { <br>if (wordCount.containsKey(word)) { <br>wordCount.put(word, wordCount.get(word) + 1); <br>} else { <br>wordCount.put(word, 1); <br>} <br>} <br><br>System.out.println("Word Occurrence:"); <br>for (String word : wordCount.keySet()) { <br>System.out.println(word + " : " + wordCount.get(word)); <br>} <br>} <br>} <br>4. Write a program to copy one HashMap to another HashMap <br>java <br>import java.util.HashMap; <br><br>public class CopyHashMapExample { <br>public static void main(String[] args) { <br>HashMap&lt;Integer, String&gt; original = new HashMap&lt;&gt;(); <br>original.put(1, "Apple"); <br>original.put(2, "Banana"); <br>original.put(3, "Mango"); <br><br>HashMap&lt;Integer, String&gt; copy = new HashMap&lt;&gt;(); <br>copy.putAll(original); <br><br>System.out.println("Original HashMap: " + original); <br>System.out.println("Copied HashMap: " + copy); <br>} <br>} <br>5. Java Program to print all duplicate characters in a String <br>java <br>import java.util.HashMap; <br><br>public class DuplicateCharacters { <br>public static void main(String[] args) { <br>String str = "programming"; <br>HashMap&lt;Character, Integer&gt; charCount = new HashMap&lt;&gt;(); <br>str = str.toLowerCase(); <br><br>for (int i = 0; i &lt; str.length(); i++) { <br>char ch = str.charAt(i); <br>if (charCount.containsKey(ch)) { <br>charCount.put(ch, charCount.get(ch) + 1); <br>} else { <br>charCount.put(ch, 1); <br>} <br>} <br><br>System.out.println("Duplicate characters:"); <br>for (Character ch : charCount.keySet()) { <br>if (charCount.get(ch) &gt; 1) { <br>System.out.println(ch + " : " + charCount.get(ch)); <br>} <br>} <br>} <br>} <br>6. Java Program to convert HashMap to TreeMap <br>java <br>import java.util.HashMap; <br>import java.util.TreeMap; <br><br>public class HashMapToTreeMap { <br>public static void main(String[] args) { <br>HashMap&lt;Integer, String&gt; hashMap = new HashMap&lt;&gt;(); <br>hashMap.put(3, "Mango"); <br>hashMap.put(1, "Apple"); <br>hashMap.put(4, "Orange"); <br>hashMap.put(2, "Banana"); <br><br>System.out.println("HashMap: " + hashMap); <br><br>TreeMap&lt;Integer, String&gt; treeMap = new TreeMap&lt;&gt;(hashMap); <br>System.out.println("TreeMap (Sorted by Keys): " + treeMap); <br>} <br>} <br>7. Write a program to sort HashSet <br>java <br>import java.util.HashSet; <br>import java.util.TreeSet; <br><br>public class SortHashSet { <br>public static void main(String[] args) { <br>HashSet&lt;String&gt; fruits = new HashSet&lt;&gt;(); <br>fruits.add("Mango"); <br>fruits.add("Apple"); <br>fruits.add("Banana"); <br>fruits.add("Orange"); <br><br>System.out.println("Original HashSet: " + fruits); <br><br>TreeSet&lt;String&gt; sortedSet = new TreeSet&lt;&gt;(fruits); <br>System.out.println("Sorted HashSet: " + sortedSet); <br>} <br>} <br>8. Write a program to convert Array to HashSet <br>java <br>import java.util.*; <br><br>public class ArrayToHashSet { <br>public static void main(String[] args) { <br>String[] arr = {"Apple", "Banana", "Mango", "Apple"}; <br>HashSet&lt;String&gt; set = new HashSet&lt;&gt;(Arrays.asList(arr)); <br>System.out.println("HashSet: " + set); <br>} <br>} <br>9. Write a program to add elements in Stack Collection <br>java <br>import java.util.*; <br><br>public class StackExample { <br>public static void main(String[] args) { <br>Stack&lt;String&gt; stack = new Stack&lt;&gt;(); <br>stack.push("Apple"); <br>stack.push("Banana"); <br>stack.push("Mango"); <br><br>System.out.println("Stack: " + stack); <br>System.out.println("Top element: " + stack.peek()); <br>System.out.println("Popped element: " + stack.pop()); <br>System.out.println("Stack after pop: " + stack); <br>} <br>} <br>10. Write a program to implement a Circular Queue <br>java <br>class CircularQueue { <br>int[] queue; <br>int front = -1, rear = -1; <br>int size; <br><br>CircularQueue(int size) { <br>this.size = size; <br>queue = new int[size]; <br>} <br><br>void enqueue(int data) { <br>if ((rear + 1) % size == front) { <br>System.out.println("Queue is Full"); <br>return; <br>} <br>if (front == -1) front = 0; <br>rear = (rear + 1) % size; <br>queue[rear] = data; <br>} <br><br>void display() { <br>if (front == -1) { <br>System.out.println("Queue is Empty"); <br>return; <br>} <br>int i = front; <br>while (true) { <br>System.out.print(queue[i] + " "); <br>if (i == rear) break; <br>i = (i + 1) % size; <br>} <br>System.out.println(); <br>} <br><br>public static void main(String[] args) { <br>CircularQueue cq = new CircularQueue(5); <br>cq.enqueue(10); <br>cq.enqueue(20); <br>cq.enqueue(30); <br>cq.display(); <br>} <br>} <br>11. Write a program to convert a List to a Queue <br>java <br>import java.util.*; <br><br>public class ListToQueue { <br>public static void main(String[] args) { <br>List&lt;String&gt; list = Arrays.asList("Apple", "Banana", "Mango"); <br>Queue&lt;String&gt; queue = new LinkedList&lt;&gt;(list); <br>System.out.println("Queue: " + queue); <br>} <br>} <br>12. Create a TreeMap to store the mappings of words to their frequencies in a given text <br>java <br>import java.util.*; <br><br>public class TreeMapFrequency { <br>public static void main(String[] args) { <br>String text = "apple banana apple mango banana"; <br>TreeMap&lt;String, Integer&gt; map = new TreeMap&lt;&gt;(); <br><br>for (String word : text.split(" ")) { <br>map.put(word, map.getOrDefault(word, 0) + 1); <br>} <br><br>System.out.println("Word Frequencies: " + map); <br>} <br>} <br>13. Implement a PriorityQueue and add elements, then print elements in sorted order <br>java <br>import java.util.*; <br><br>public class PriorityQueueExample { <br>public static void main(String[] args) { <br>PriorityQueue&lt;Integer&gt; pq = new PriorityQueue&lt;&gt;(); <br>pq.add(30); <br>pq.add(10); <br>pq.add(20); <br><br>System.out.println("PriorityQueue Elements (sorted order):"); <br>while (!pq.isEmpty()) { <br>System.out.println(pq.poll()); <br>} <br>} <br>} <br>14. Implement a Stack using the ArrayDeque class <br>java <br>import java.util.*; <br><br>public class StackUsingDeque { <br>public static void main(String[] args) { <br>ArrayDeque&lt;String&gt; stack = new ArrayDeque&lt;&gt;(); <br>stack.push("Apple"); <br>stack.push("Banana"); <br>stack.push("Mango"); <br><br>System.out.println("Stack: " + stack); <br>System.out.println("Pop: " + stack.pop()); <br>System.out.println("Stack after pop: " + stack); <br>} <br>} <br>15. Implement a Queue using the ArrayDeque class <br>java <br>import java.util.*; <br><br>public class QueueUsingDeque { <br>public static void main(String[] args) { <br>ArrayDeque&lt;String&gt; queue = new ArrayDeque&lt;&gt;(); <br>queue.offer("Apple"); <br>queue.offer("Banana"); <br>queue.offer("Mango"); <br><br>System.out.println("Queue: " + queue); <br>System.out.println("Poll: " + queue.poll()); <br>System.out.println("Queue after poll: " + queue); <br>} <br>} <br>1. LIST FILES IN A DIRECTORY <br><br>import java.io.File; <br><br>public class ListFiles { <br>public static void main(String[] args) { <br>File folder = new File("."); <br><br>File[] files = folder.listFiles(); <br><br>for (File file : files) { <br>if (file.isFile()) { <br>System.out.println(file.getName()); <br>} <br>} <br>} <br>} <br><br>2.CREATE A NEW FILE AND ADD DATA <br><br>import java.io.FileWriter; <br>import java.io.IOException; <br><br>public class CreateFile { <br>public static void main(String[] args) throws IOException { <br>FileWriter fw = new FileWriter("sample.txt"); <br>fw.write("Hello this is a new file."); <br>fw.close(); <br><br>System.out.println("File created and data written."); <br>} <br>} <br><br>3.READ DATA FROM THE USER AND ADD IT TO A NEW FILE <br><br>import java.io.FileWriter; <br>import java.util.Scanner; <br><br>public class UserToFile { <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.println("Enter text:"); <br>String text = sc.nextLine(); <br><br>FileWriter fw = new FileWriter("newfile.txt"); <br>fw.write(text); <br>fw.close(); <br>} <br>} <br><br>4.READ DATA FROM THE USER AND TO THE EXISTING FILE <br><br>import java.io.FileWriter; <br>import java.util.Scanner; <br><br>public class AppendFile { <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.println("Enter text:"); <br>String text = sc.nextLine(); <br><br>FileWriter fw = new FileWriter("sample.txt", true); <br>fw.write(text); <br>fw.close(); <br>} <br>} <br><br>5.READ DATA FROM THE FILE AND PRINT IT TO CONSOLE <br><br>import java.io.File; <br>import java.util.Scanner; <br><br>public class ReadFile { <br>public static void main(String[] args) throws Exception { <br>File file = new File("sample.txt"); <br>Scanner sc = new Scanner(file); <br><br>while(sc.hasNextLine()) { <br>System.out.println(sc.nextLine()); <br>} <br>} <br>} <br><br>6.TRANSFER CONTENT FROM ONE FILE TO ANOTHER <br><br>import java.io.*; <br><br>public class CopyFile { <br>public static void main(String[] args) throws Exception { <br>FileReader fr = new FileReader("source.txt"); <br>FileWriter fw = new FileWriter("dest.txt"); <br><br>int ch; <br>while((ch = fr.read()) != -1) { <br>fw.write(ch); <br>} <br><br>fr.close(); <br>fw.close(); <br>} <br>} <br><br>7.STORE FILE LINES FROM THE VARIABLE <br><br>import java.io.File; <br>import java.util.Scanner; <br><br>public class StoreLines { <br>public static void main(String[] args) throws Exception { <br>File file = new File("sample.txt"); <br>Scanner sc = new Scanner(file); <br><br>String content = ""; <br><br>while(sc.hasNextLine()) { <br>content += sc.nextLine() + "\n"; <br>} <br><br>System.out.println(content); <br>} <br>} <br><br>8.READ FIRST 3 LINES OF A FILE <br><br>import java.io.File; <br>import java.util.Scanner; <br><br>public class FirstThreeLines { <br>public static void main(String[] args) throws Exception { <br>File file = new File("sample.txt"); <br>Scanner sc = new Scanner(file); <br><br>for(int i=1;i&lt;=3 &amp;&amp; sc.hasNextLine();i++) { <br>System.out.println(sc.nextLine()); <br>} <br>} <br>} <br><br>9.FIND LONGEST WORD IN A FILE <br><br>import java.io.File; <br>import java.util.Scanner; <br><br>public class LongestWord { <br>public static void main(String[] args) throws Exception { <br>File file = new File("sample.txt"); <br>Scanner sc = new Scanner(file); <br><br>String longest = ""; <br><br>while(sc.hasNext()) { <br>String word = sc.next(); <br>if(word.length() &gt; longest.length()) { <br>longest = word; <br>} <br>} <br><br>System.out.println("Longest word: " + longest); <br>} <br>} <br>Java Assignment - JDBC Database Connection <br>java <br>import java.sql.*; <br><br>public class SimpleDBConnect { <br>public static void main(String[] args) { <br>try { <br>// 1. Load driver (optional for newer Java versions) <br>Class.forName("com.mysql.cj.jdbc.Driver"); <br><br>// 2. Connect to database <br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/mydb", "root", ""); <br><br>// 3. Create statement <br>Statement stmt = con.createStatement(); <br><br>// 4. Execute query <br>ResultSet rs = stmt.executeQuery("SELECT * FROM employee"); <br><br>// 5. Display results <br>while (rs.next()) { <br>System.out.println(rs.getInt("EmpID") + " | " + <br>rs.getString("EmpName") + " | " + <br>rs.getString("Dept") + " | " + <br>rs.getInt("Salary")); <br>} <br><br>// 6. Close connection <br>con.close(); <br><br>} catch (Exception e) { <br>System.out.println("Error: " + e.getMessage()); <br>} <br>} <br>} <br>1. Write a Java program to SELECT data from database using PreparedStatement where the selection criteria is taken as input from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class SelectData{ <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter rollno: "); <br>int id = sc.nextInt(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/student", "root", "password"); <br><br>String query = "SELECT * FROM students WHERE rollno = ?"; <br>PreparedStatement ps = con.prepareStatement(query); <br>ps.setInt(1, rollno); <br><br>ResultSet rs = ps.executeQuery(); <br><br>while (rs.next()) { <br>System.out.println(rs.getInt("rollno") + " " + <br>rs.getString("name") + " " + <br>rs.getInt("age")); <br>} <br><br>con.close(); <br>} <br>} <br><br><br>2. Write a Java program to INSERT data into database using Statement where values are taken from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class InsertData{ <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter RollNo: "); <br>int id = sc.nextInt(); <br>System.out.print("Enter name: "); <br>String name = sc.next(); <br>System.out.print("Enter age: "); <br>int age = sc.nextInt(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/student", "root", "password"); <br><br>Statement stmt = con.createStatement(); <br><br>String query = "INSERT INTO students VALUES(" + rollno+ ", '" + name + "', " + age + ", NULL)"; <br>stmt.executeUpdate(query); <br><br>System.out.println("Inserted successfully"); <br>con.close(); <br>} <br>} <br><br><br>3. Write a Java program to INSERT data into database using PreparedStatement where values are taken from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class InsertData{ <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter rollno: "); <br>int id = sc.nextInt(); <br>System.out.print("Enter name: "); <br>String name = sc.next(); <br>System.out.print("Enter age: "); <br>int age = sc.nextInt(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/student", "root", "password"); <br><br>String query = "INSERT INTO students(rollno, name, age) VALUES (?, ?, ?)"; <br>PreparedStatement ps = con.prepareStatement(query); <br><br>ps.setInt(1, rollno); <br>ps.setString(2, name); <br>ps.setInt(3, age); <br><br>ps.executeUpdate(); <br><br>con.close(); <br>} <br>} <br><br><br>4. Write a Java program to UPDATE data using Statement where update value and criteria are taken from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class UpdateData{ <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter rollno to update: "); <br>int rollno= sc.nextInt(); <br>System.out.print("Enter new age: "); <br>int age = sc.nextInt(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/student", "root", "password"); <br><br>Statement stmt = con.createStatement(); <br><br>String query = "UPDATE students SET age = " + age + " WHERE rollno = " + rollno; <br>stmt.executeUpdate(query); <br><br>System.out.println("Updated successfully"); <br>con.close(); <br>} <br>} <br><br><br>5. Write a Java program to UPDATE data using PreparedStatement where update value and criteria are taken from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class UpdateData{ <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter rollno: "); <br>int rollno= sc.nextInt(); <br>System.out.print("Enter new age: "); <br>int age = sc.nextInt(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/students", "root", "password"); <br><br>String query = "UPDATE students SET age = ? WHERE rollno = ?"; <br>PreparedStatement ps = con.prepareStatement(query); <br><br>ps.setInt(1, age); <br>ps.setInt(2, rollno); <br><br>ps.executeUpdate(); <br><br>con.close(); <br>} <br>} <br><br><br>6. Write a Java program to SELECT data using Statement where selection criteria is taken from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class SelectData{ <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter rollno: "); <br>int rollno= sc.nextInt(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/student", "root", "password"); <br><br>Statement stmt = con.createStatement(); <br><br>String query = "SELECT * FROM students WHERE rollno= " + rollno; <br>ResultSet rs = stmt.executeQuery(query); <br><br>while (rs.next()) { <br>System.out.println(rs.getInt("rollno") + " " + rs.getString("name")); <br>} <br><br>con.close(); <br>} <br>} <br><br><br>7. Write a Java program to INSERT Date into database using PreparedStatement where date is taken from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class InsertDate { <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter rollno: "); <br>int rollno= sc.nextInt(); <br>System.out.print("Enter date of birth(yyyy-mm-dd): "); <br>String Input = sc.next(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/student", "root", "password"); <br><br>String query = "INSERT INTO students(rollno, dob) VALUES (?, ?)"; <br>PreparedStatement ps = con.prepareStatement(query); <br><br>ps.setInt(1, rollno); <br>ps.setDate(2, Date.valueOf(Input)); <br><br>ps.executeUpdate(); <br>con.close(); <br>} <br>} <br><br><br>8. Write a Java program to UPDATE Date of Birth using PreparedStatement where date and criteria are taken from user. <br>import java.sql.*; <br>import java.util.Scanner; <br><br>public class UpdateDOB{ <br>public static void main(String[] args) throws Exception { <br>Scanner sc = new Scanner(System.in); <br><br>System.out.print("Enter rollno: "); <br>int rollno= sc.nextInt(); <br>System.out.print("Enter new Date of birth(yyyy-mm-dd): "); <br>String Input = sc.next(); <br><br>Connection con = DriverManager.getConnection( <br>"jdbc:mysql://localhost:3306/student", "root", "password"); <br><br>String query = "UPDATE students SET dob = ? WHERE rollno= ?"; <br>PreparedStatement ps = con.prepareStatement(query); <br><br>ps.setDate(1, Date.valueOf(Input)); <br>ps.setInt(2, rollno); <br><br>ps.executeUpdate(); <br><br>con.close(); <br>} <br>} <br><br><br><br><br><br><br><br></p></body></html>